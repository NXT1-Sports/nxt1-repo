rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ─────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated()
        && firestore.get(/databases/(default)/documents/Users/$(request.auth.uid)).data.role == 'admin';
    }
    function isImageType() {
      return request.resource.contentType.matches('image/.*');
    }

    // ── Profiles/ProfileImages/{userId}/ ────────────────────────────────
    // Only the owning user can write profile images.
    // Any authenticated user can read (public profiles).
    // No size limit — sharp normalizes input to 800×800 JPEG before upload.
    match /Profiles/ProfileImages/{userId}/{allPaths=**} {
      allow read:   if isAuthenticated();
      allow write:  if isOwner(userId) && isImageType();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ── Teams/ ───────────────────────────────────────────────────────────
    // Team logos are uploaded server-side — write requires admin.
    match /Teams/{allPaths=**} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Colleges/ ────────────────────────────────────────────────────────
    match /Colleges/{allPaths=**} {
      allow read:  if true; // Public CDN assets
      allow write: if isAdmin();
    }

    // ── Conferences/ ─────────────────────────────────────────────────────
    match /Conferences/{allPaths=**} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Fonts/ ───────────────────────────────────────────────────────────
    match /Fonts/{allPaths=**} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Default: deny everything else ───────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
