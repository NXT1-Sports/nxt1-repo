{
  "name": "@nxt1/core",
  "version": "1.30.0",
  "description": "NXT1 Core - Pure TypeScript shared library for all platforms",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "import": "./dist/models/index.js",
      "require": "./dist/models/index.cjs"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.js",
      "require": "./dist/constants/index.cjs"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js",
      "require": "./dist/api/index.cjs"
    },
    "./live-update": {
      "types": "./dist/live-update/index.d.ts",
      "import": "./dist/live-update/index.js",
      "require": "./dist/live-update/index.cjs"
    },
    "./helpers": {
      "types": "./dist/helpers/index.d.ts",
      "import": "./dist/helpers/index.js",
      "require": "./dist/helpers/index.cjs"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js",
      "require": "./dist/validation/index.cjs"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs"
    },
    "./platform": {
      "types": "./dist/platform/index.d.ts",
      "import": "./dist/platform/index.js",
      "require": "./dist/platform/index.cjs"
    },
    "./analytics": {
      "types": "./dist/analytics/index.d.ts",
      "import": "./dist/analytics/index.js",
      "require": "./dist/analytics/index.cjs"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "import": "./dist/cache/index.js",
      "require": "./dist/cache/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.cjs"
    },
    "./errors/express": {
      "types": "./dist/errors/express.middleware.d.ts",
      "import": "./dist/errors/express.middleware.js",
      "require": "./dist/errors/express.middleware.cjs"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "import": "./dist/logging/index.js",
      "require": "./dist/logging/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs"
    },
    "./geolocation": {
      "types": "./dist/geolocation/index.d.ts",
      "import": "./dist/geolocation/index.js",
      "require": "./dist/geolocation/index.cjs"
    },
    "./crashlytics": {
      "types": "./dist/crashlytics/index.d.ts",
      "import": "./dist/crashlytics/index.js",
      "require": "./dist/crashlytics/index.cjs"
    },
    "./performance": {
      "types": "./dist/performance/index.d.ts",
      "import": "./dist/performance/index.js",
      "require": "./dist/performance/index.cjs"
    },
    "./posts": {
      "types": "./dist/posts/index.d.ts",
      "import": "./dist/posts/index.js",
      "require": "./dist/posts/index.cjs"
    },
    "./create-post": {
      "types": "./dist/create-post/index.d.ts",
      "import": "./dist/create-post/index.js",
      "require": "./dist/create-post/index.cjs"
    },
    "./onboarding": {
      "types": "./dist/onboarding/index.d.ts",
      "import": "./dist/onboarding/index.js",
      "require": "./dist/onboarding/index.cjs"
    },
    "./platforms": {
      "types": "./dist/platforms/index.d.ts",
      "import": "./dist/platforms/index.js",
      "require": "./dist/platforms/index.cjs"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.js",
      "require": "./dist/ai/index.cjs"
    },
    "./usage": {
      "types": "./dist/usage/index.d.ts",
      "import": "./dist/usage/index.js",
      "require": "./dist/usage/index.cjs"
    },
    "./team-profile": {
      "types": "./dist/team-profile/index.d.ts",
      "import": "./dist/team-profile/index.js",
      "require": "./dist/team-profile/index.cjs"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js",
      "require": "./dist/*/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsup && node -e \"require('fs').rmSync('dist/.tsbuildinfo',{force:true})\" && tsc --emitDeclarationOnly --declaration --declarationMap --project tsconfig.json && node scripts/fix-dist-imports.mjs",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo node_modules"
  },
  "dependencies": {
    "tsup": "^8.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^7.0.3",
    "firebase": "^12.9.0",
    "rimraf": "^6.1.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "firebase": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "firebase": {
      "optional": true
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "restricted"
  },
  "keywords": [
    "nxt1",
    "core",
    "shared",
    "types",
    "models"
  ]
}
