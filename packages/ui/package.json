{
  "name": "@nxt1/ui",
  "version": "1.1.0",
  "description": "NXT1 UI - Shared Angular/Ionic components for cross-platform applications",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src/styles"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/nxt1-ui.mjs"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/fesm2022/nxt1-ui-auth.mjs"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "default": "./dist/fesm2022/nxt1-ui-shared.mjs"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "default": "./dist/fesm2022/nxt1-ui-services.mjs"
    },
    "./directives": {
      "types": "./dist/directives/index.d.ts",
      "default": "./dist/fesm2022/nxt1-ui-directives.mjs"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/fesm2022/nxt1-ui-components.mjs"
    },
    "./styles": "./src/styles/index.css",
    "./styles/auth": "./src/styles/auth/auth.css"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "build:watch": "ng-packagr -p ng-package.json --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@nxt1/core": "*",
    "@nxt1/design-tokens": "*"
  },
  "peerDependencies": {
    "@angular/common": "^19.0.0 || ^20.0.0 || ^21.0.0",
    "@angular/core": "^19.0.0 || ^20.0.0 || ^21.0.0",
    "@angular/forms": "^19.0.0 || ^20.0.0 || ^21.0.0",
    "@capacitor/core": "^6.0.0 || ^7.0.0",
    "@ionic/angular": "^8.0.0",
    "ionicons": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@capacitor/core": {
      "optional": true
    },
    "capacitor-native-biometric": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@ionic/angular": "^8.5.0",
    "ionicons": "^7.4.0",
    "ng-packagr": "^21.0.0",
    "typescript": "~5.9.3"
  },
  "keywords": [
    "angular",
    "ionic",
    "components",
    "ui",
    "cross-platform",
    "mobile",
    "nxt1"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}
