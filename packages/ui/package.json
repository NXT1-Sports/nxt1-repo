{
  "name": "@nxt1/ui",
  "version": "2.19.0",
  "description": "NXT1 UI - Shared Angular/Ionic components, services, and infrastructure for cross-platform applications (2026 APF)",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src/styles"
  ],
  "exports": {
    "./styles": "./src/styles/index.css",
    "./styles/base": "./src/styles/base/index.css",
    "./styles/base/variables": "./src/styles/base/variables.css",
    "./styles/base/buttons": "./src/styles/base/buttons.css",
    "./styles/base/forms": "./src/styles/base/forms.css",
    "./styles/base/links": "./src/styles/base/links.css",
    "./styles/base/accessibility": "./src/styles/base/accessibility.css",
    "./styles/auth": "./src/styles/features/auth.css",
    "./styles/features/auth": "./src/styles/features/auth.css",
    "./styles/components/ionic-select": "./src/styles/components/ionic-select.css",
    "./styles/components/ionic-toast": "./src/styles/components/ionic-toast.css",
    "./styles/components/ionic-modal": "./src/styles/components/ionic-modal.css",
    "./styles/components/ionic-biometric-modal": "./src/styles/components/ionic-biometric-modal.css",
    "./styles/components/biometric-modal": "./src/styles/components/biometric-modal.css",
    "./styles/components/bottom-sheet": "./src/styles/components/bottom-sheet.css",
    "./styles/components/sheet-modal": "./src/styles/components/sheet-modal.css",
    "./styles/components/modal": "./src/styles/components/modal.css",
    "./styles/components/navigation": "./src/styles/components/navigation.css",
    "./styles/components/qr-code-modal": "./src/styles/components/qr-code-modal.css",
    "./styles/animations": "./src/styles/animations.css"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "build:watch": "ng-packagr -p ng-package.json --watch",
    "dev": "ng-packagr -p ng-package.json --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@nxt1/core": "*",
    "@nxt1/design-tokens": "*",
    "@stripe/stripe-js": "^5.10.0",
    "zod": "^4.3.6",
    "marked": "^17.0.0",
    "dompurify": "^3.4.0"
  },
  "peerDependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@capacitor/action-sheet": "^6.0.0 || ^7.0.0 || ^8.0.0",
    "@capacitor/core": "^6.0.0 || ^7.0.0 || ^8.0.0",
    "@capacitor/dialog": "^6.0.0 || ^7.0.0 || ^8.0.0",
    "@capacitor/haptics": "^6.0.0 || ^7.0.0 || ^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@ionic/angular": "^8.0.0",
    "ionicons": "^7.0.0 || ^8.0.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@capacitor/action-sheet": {
      "optional": true
    },
    "@capacitor/core": {
      "optional": true
    },
    "@capacitor/dialog": {
      "optional": true
    },
    "@capacitor/haptics": {
      "optional": true
    },
    "@angular/cdk": {
      "optional": true
    },
    "capacitor-native-biometric": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ionic/angular": "^8.5.0",
    "ionicons": "^8.0.13",
    "ng-packagr": "^21.0.0",
    "rxjs": "^7.8.1",
    "typescript": "~5.9.3"
  },
  "keywords": [
    "angular",
    "ionic",
    "components",
    "services",
    "infrastructure",
    "ui",
    "cross-platform",
    "mobile",
    "nxt1"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}
