{
  "name": "@nxt1/cache",
  "version": "1.22.0",
  "description": "Cache abstraction with Redis and in-memory fallback",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('tsconfig.tsbuildinfo',{force:true})\" && tsc",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "redis": "^5.10.0"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  }
}
