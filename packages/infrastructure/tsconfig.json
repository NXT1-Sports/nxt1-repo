{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@nxt1/core": ["../core/src/index.ts"],
      "@nxt1/core/*": ["../core/src/*/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "compilationMode": "partial",
    "strictTemplates": true,
    "strictInjectionParameters": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
