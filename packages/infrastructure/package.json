{
  "name": "@nxt1/infrastructure",
  "version": "1.0.0",
  "description": "NXT1 Infrastructure - Cross-cutting Angular services for auth, network, and platform concerns",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "build:watch": "ng-packagr -p ng-package.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "@nxt1/core": "*",
    "@angular/common": "^19.0.0 || ^20.0.0 || ^21.0.0",
    "@angular/core": "^19.0.0 || ^20.0.0 || ^21.0.0",
    "@capacitor/core": "^6.0.0 || ^7.0.0",
    "@capacitor/network": "^6.0.0 || ^7.0.0",
    "@ionic/angular": "^8.0.0",
    "capacitor-native-biometric": "^4.0.0",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "@capacitor/core": {
      "optional": true
    },
    "@capacitor/network": {
      "optional": true
    },
    "capacitor-native-biometric": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/network": "^7.0.0",
    "@ionic/angular": "^8.5.0",
    "capacitor-native-biometric": "^4.2.2",
    "ng-packagr": "^21.0.0",
    "rxjs": "^7.8.0",
    "typescript": "~5.9.3"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
