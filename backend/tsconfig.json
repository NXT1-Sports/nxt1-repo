{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "noEmit": false,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@nxt1/core": ["../packages/core/dist/index.d.ts"],
      "@nxt1/core/errors/express": [
        "../packages/core/dist/errors/express.middleware.d.ts"
      ],
      "@nxt1/core/*": [
        "../packages/core/dist/*/index.d.ts",
        "../packages/core/dist/*.d.ts"
      ],
      "@nxt1/cache": ["../packages/cache/dist/index.d.ts"],
      "@nxt1/cache/*": ["../packages/cache/dist/*.d.ts"]
    }
  },
  "references": [
    { "path": "../packages/core" },
    { "path": "../packages/cache" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
