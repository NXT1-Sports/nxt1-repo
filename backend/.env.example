# Server Configuration
PORT=3000
NODE_ENV=development
secret=''

# Backend URL (used for internal service calls)
BACKEND_URL=''

# Frontend App Base URLs (used for invite links, QR codes, etc.)
# APP_URL overrides the resolved URL in ALL environments (useful for ngrok tunnels).
# In development NODE_ENV the default is http://localhost:4200 (web app dev server).
# In staging/production it defaults to the known domain.
APP_URL=http://localhost:4200

# MongoDB
MONGO=""
MONGO2=""
MONGO_AI=""
# MongoDB backup
TEST_MONGO=""
TEST_MONGO2=""

# Google
nylasClientId = ''
nylasClientSecret = ''
CLIENT_ID = ''
CLIENT_SECRET = ''
REDIRECT_URI = ''
REFRESH_TOKEN = ''
# Microsoft
MICROSOFT_CLIENT_ID = ''
MICROSOFT_CLIENT_SECRET = ''
MICROSOFT_TENANT_ID = ''
# Yahoo
YAHOO_CLIENT_ID = ''
YAHOO_CLIENT_SECRET = ''

# Production Firebase (nxt-1-v2)
FIREBASE_PROJECT_ID=nxt-1-v2
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@nxt-1-v2.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=nxt-1-v2.firebasestorage.app

# Staging Firebase (nxt-1-staging-v2)
STAGING_CLIENT_ID=''
STAGING_FIREBASE_PROJECT_ID=nxt-1-staging-v2
STAGING_FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@nxt-1-staging-v2.iam.gserviceaccount.com
STAGING_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
STAGING_FIREBASE_STORAGE_BUCKET=nxt-1-staging-v2.firebasestorage.app

# JWT
JWT_SECRET=your-very-long-random-jwt-secret

# Redis
REDIS_URL=redis://localhost:6379
# DB 0 = production, DB 1 = staging
REDIS_DB=0

# Stripe
STRIPE_SECRET_KEY = 'sk_live...'
STRIPE_PUBLISHABLE_KEY = 'pk_live_...'
STRIPE_SUBSCRIPTION_66 = ''
STRIPE_SUBSCRIPTION_36 = ''
STRIPE_ONE_TIME_PAYMENTS_21 = ''
STRIPE_ONE_TIME_PAYMENTS_41 = ''
STRIPE_WEBHOOK_SECRET='whsec_...'
STRIPE_TEST_SECRET_KEY = ''
STRIPE_TEST_PUBLISHABLE_KEY = ''
STRIPE_TEST_ONE_TIME_PAYMENTS_21 = ''
STRIPE_TEST_ONE_TIME_PAYMENTS_41 = ''
STRIPE_TEST_SUBSCRIPTION_66 = ''
STRIPE_TEST_WEBHOOK_SECRET=''
# PayPal
PAYPAL_CLIENT_ID = ''
PAYPAL_CLIENT_SECRET = ''
# Apple
APPLE_SHARED_SECRET = ''
APPLE_BUNDLE_ID=''
APPLE_APP_ID=''
# CloudConvert
NXT1_CLOUDCONVERT_APIKEY = ''
NXT1_CLOUDCONVERT_APIKEY_BACKUP = ''
# AI Services
OPENROUTER_API_KEY = ''
OPENROUTER_MODEL = ''
# OPENROUTER_API_KEY is a Helicone virtual key — embeddings require a direct key.
# Disable semantic cache until a real embeddings-capable key is configured.
SEMANTIC_CACHE_ENABLED=false
# Helicone — AI observability & cost tracking (https://helicone.ai → Settings → API Keys)
# Required for billing to work: LLM spend tracking, per-job cost calculation
HELICONE_API_KEY = ''
FIRECRAWL_API_KEY = ''
META_VERIFY_TOKEN = ''
SIGHTENGINE_API_USER = ''
SIGHTENGINE_API_SECRET = ''
RUNWAYML_API_SECRET=''
# Legacy alias still supported by the bridge for older local env files:
# RUNWAY_API_KEY=''
# Cloudflare Stream
CLOUDFLARE_API_TOKEN=''
CLOUDFLARE_ACCOUNT_ID=''
CLOUDFLARE_STREAM_CUSTOMER_CODE=''
CLOUDFLARE_WEBHOOK_SECRET=''
# Cron job authentication secret (shared between backend and Firebase Functions)
CRON_SECRET=''
# Apify — Twitter/X scraping via hosted Scweet actor (https://console.apify.com → Settings → API Tokens)
APIFY_API_TOKEN=''