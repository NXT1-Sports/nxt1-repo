{
  "name": "@nxt1/backend",
  "version": "1.0.0",
  "description": "NXT1 Backend API Server",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node --require dotenv/config dist/index.js",
    "dev": "nodemon --watch src --ext ts,js,json --exec \"npm run build && npm start\"",
    "build": "rimraf tsconfig.tsbuildinfo && tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist tsconfig.tsbuildinfo node_modules",
    "deploy:staging": "gcloud app deploy --project nxt1-staging",
    "deploy:prod": "gcloud app deploy --project nxt1-production"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.0.0",
    "@nxt1/core": "*",
    "axios": "^1.13.2",
    "body-parser": "^2.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase-admin": "^13.6.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.1",
    "multer": "^2.0.2",
    "stripe": "^20.1.0"
  },
  "devDependencies": {
    "@nxt1/config": "*",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.11",
    "rimraf": "^5.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  }
}
