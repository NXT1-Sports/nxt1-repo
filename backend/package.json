{
  "name": "@nxt1/backend",
  "version": "1.0.0",
  "description": "NXT1 Backend API Server",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node --require dotenv/config dist/index.js",
    "dev": "nodemon --watch src --ext ts,js,json --exec \"npm run build && npm start\"",
    "build": "rimraf tsconfig.tsbuildinfo && tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist tsconfig.tsbuildinfo node_modules",
    "deploy:staging": "gcloud app deploy --project nxt1-staging",
    "deploy:prod": "gcloud app deploy --project nxt1-production",
    "migrate:search-indexes": "tsx scripts/migrate-search-indexes.ts",
    "migrate:search-indexes:dry-run": "tsx scripts/migrate-search-indexes.ts --dry-run",
    "worker:stripe": "tsx src/workers/stripe-worker.ts",
    "reconcile:usage": "tsx scripts/reconcile-usage-events.ts",
    "reconcile:usage:dry-run": "tsx scripts/reconcile-usage-events.ts --dry-run",
    "reconcile:usage:staging": "tsx scripts/reconcile-usage-events.ts --staging"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.0.0",
    "@google-cloud/pubsub": "^5.2.3",
    "@nxt1/cache": "*",
    "@nxt1/core": "*",
    "@nxt1/shared-types": "*",
    "axios": "^1.13.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^9.1.1",
    "multer": "^2.0.2",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "stripe": "^20.1.0"
  },
  "devDependencies": {
    "@nxt1/config": "*",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.3",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.11",
    "rimraf": "^6.1.2",
    "supertest": "^7.2.2",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
