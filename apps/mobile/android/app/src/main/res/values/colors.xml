<?xml version="1.0" encoding="utf-8"?>
<!--
  NXT1 Android Native Colors
  
  These colors are used by Android system UI elements:
  - Status bar (colorPrimaryDark)
  - Navigation bar (android:navigationBarColor in styles.xml)
  - Selection highlights (colorAccent)
  - Splash screen background
  
  IMPORTANT: Keep these in sync with design tokens!
  @nxt1/design-tokens values:
  - Primary: #ccff00 (neon green)
  - Background: #0a0a0a (dark)
  - Accent: #56ff00 (bright green)
-->
<resources>
    <!-- NXT1 Brand Colors -->
    <color name="colorPrimary">#CCFF00</color>           <!-- Neon green primary -->
    <color name="colorPrimaryDark">#0A0A0A</color>       <!-- Dark background (status bar) -->
    <color name="colorAccent">#CCFF00</color>            <!-- Neon green accent (selections, cursors) -->
    
    <!-- Background Colors -->
    <color name="backgroundColor">#0A0A0A</color>        <!-- App dark background -->
    <color name="splashBackgroundColor">#FFFFFF</color>  <!-- Splash screen (light mode) -->
    
    <!-- Navigation Bar -->
    <color name="navigationBarColor">#0A0A0A</color>     <!-- Bottom system nav bar -->
    
    <!-- Text Colors -->
    <color name="textColorPrimary">#FFFFFF</color>       <!-- Primary text -->
    <color name="textColorSecondary">#A3A3A3</color>     <!-- Secondary text -->
    
    <!-- Surface Colors -->
    <color name="cardBackgroundColor">#121212</color>    <!-- Card/surface background -->
    <color name="dividerColor">#262626</color>           <!-- Divider lines -->
</resources>
