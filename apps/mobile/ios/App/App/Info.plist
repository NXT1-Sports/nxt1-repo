<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>NXT1 Sports</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleLightContent</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- Geolocation Permissions (Required for @capacitor/geolocation) -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>NXT1 uses your location to automatically detect your city and state for your athlete profile, and to help you discover nearby teams and events.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>NXT1 uses your location to automatically detect your city and state for your athlete profile, and to help you discover nearby teams and events.</string>
	<!-- Camera Permissions (for profile photos) -->
	<key>NSCameraUsageDescription</key>
	<string>NXT1 needs camera access to take profile photos and capture highlight videos.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>NXT1 needs photo library access to select profile photos and highlight videos.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>NXT1 saves photos and videos to your photo library.</string>
	<!-- Biometric Authentication (Face ID / Touch ID) -->
	<key>NSFaceIDUsageDescription</key>
	<string>NXT1 uses Face ID for quick and secure sign-in to your account.</string>
	<!-- URL Schemes for OAuth Callbacks (Google Sign-In, Deep Links) -->
	<key>CFBundleURLTypes</key>
	<array>
		<!-- Google Sign-In URL Scheme (REVERSED_CLIENT_ID from GoogleService-Info.plist) -->
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.455734259010-qagtsakkvchuf3tnbgjgitjj80e740ib</string>
			</array>
			<key>CFBundleURLName</key>
			<string>Google Sign-In</string>
		</dict>
		<!-- App Deep Link Scheme -->
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>nxt1</string>
			</array>
			<key>CFBundleURLName</key>
			<string>NXT1 Deep Links</string>
		</dict>
	</array>
</dict>
</plist>
