<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Disable Firebase method swizzling so Capacitor's ApplicationDelegateProxy
	     can receive APNs callbacks (didRegisterForRemoteNotificationsWithDeviceToken).
	     Without this, Firebase intercepts APNs and PushNotifications plugin never
	     receives the registration event. -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false/>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>NXT1 Sports</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>NXT 1 Sports</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneConfigurationName</key>
					<string>Default Configuration</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleLightContent</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- NSAllowsArbitraryLoads intentionally removed: staging/production use HTTPS only.
		     NSAllowsLocalNetworking allows HTTP to local IPs (192.168.x.x) for dev live-reload. -->
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- Geolocation Permissions (Required for @capacitor/geolocation) -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>NXT1 uses your location to automatically detect your city and state for your athlete profile, and to help you discover nearby teams and events.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>NXT1 uses your location to automatically detect your city and state for your athlete profile, and to help you discover nearby teams and events.</string>
	<!-- Camera Permissions (for profile photos) -->
	<key>NSCameraUsageDescription</key>
	<string>NXT1 needs camera access to take profile photos and capture highlight videos.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>NXT1 needs photo library access to select profile photos and highlight videos.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>NXT1 saves photos and videos to your photo library.</string>
	<!-- Biometric Authentication (Face ID / Touch ID) -->
	<key>NSFaceIDUsageDescription</key>
	<string>NXT1 uses Face ID for quick and secure sign-in to your account.</string>
	<!-- URL Schemes for OAuth Callbacks (Google Sign-In, Deep Links) -->
	<key>CFBundleURLTypes</key>
	<array>
		<!-- Google Sign-In URL Schemes (REVERSED_CLIENT_ID for both staging and production) -->
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<!-- Active GoogleService-Info.plist (nxt1 staging v2) -->
				<string>com.googleusercontent.apps.1099429444442-n4nnpevnqm8on4dp91il0f6rl39e3nvs</string>
				<!-- Active GoogleService-Info.plist (nxt1 production v2) -->
				<string>com.googleusercontent.apps.112256620070-hhqncoijt5f2or5218dmtq43moa6vgup</string>
			</array>
			<key>CFBundleURLName</key>
			<string>Google Sign-In</string>
		</dict>
		<!-- Microsoft MSAL URL Scheme -->
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>msauth.$(PRODUCT_BUNDLE_IDENTIFIER)</string>
				<string>msalaaceb7d3-bc1d-4c44-a871-cb96826558de</string>
			</array>
			<key>CFBundleURLName</key>
			<string>Microsoft Auth</string>
		</dict>
		<!-- App Deep Link Scheme (custom URL scheme fallback) -->
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>nxt1</string>
				<string>nxt1sports</string>
			</array>
			<key>CFBundleURLName</key>
			<string>NXT1 Deep Links</string>
		</dict>
	</array>
	<!-- Microsoft Auth Query Schemes -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>msauthv2</string>
		<string>msauthv3</string>
	</array>
</dict>
</plist>
