{
  "name": "@nxt1/mobile",
  "version": "1.0.0",
  "description": "NXT1 Mobile Application - Ionic + Capacitor",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve",
    "dev:host": "ng serve --host 0.0.0.0",
    "build": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist www .angular node_modules",
    "sync": "npx cap sync",
    "ios": "npm run build && npx cap sync ios && npx cap open ios",
    "android": "npm run build && npx cap sync android && npx cap open android",
    "ios:dev": "npm run build:dev && npx cap sync ios && npx cap run ios",
    "android:dev": "npm run build:dev && npx cap sync android && npx cap run android",
    "ios:live": "npx cap sync ios && npx cap run ios --live-reload",
    "android:live": "npx cap sync android && npx cap run android --live-reload",
    "resources": "npx @capacitor/assets generate",
    "clean:soft": "rm -rf dist www .angular",
    "rebuild:ios": "npm run clean:soft && npm run build:dev && npx cap sync ios && npx cap open ios",
    "rebuild:android": "npm run clean:soft && npm run build:dev && npx cap sync android && npx cap open android",
    "rebuild:live:ios": "npm run clean:soft && npm run build:dev && npx cap sync ios && npx cap run ios --live-reload",
    "rebuild:live:android": "npm run clean:soft && npm run build:dev && npx cap sync android && npx cap run android --live-reload"
  },
  "dependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/common": "^21.0.6",
    "@angular/compiler": "^21.0.6",
    "@angular/core": "^21.0.6",
    "@angular/forms": "^21.0.6",
    "@angular/platform-browser": "^21.0.6",
    "@angular/platform-browser-dynamic": "^21.0.6",
    "@angular/router": "^21.0.6",
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/camera": "^7.0.0",
    "@capacitor/core": "^7.2.0",
    "@capacitor/device": "^7.0.0",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.2.0",
    "@capacitor/keyboard": "^7.0.0",
    "@capacitor/network": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "@capacitor/push-notifications": "^7.0.0",
    "@capacitor/share": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@ionic/angular": "^8.6.0",
    "@nxt1/core": "*",
    "@nxt1/ui": "*",
    "capacitor-native-biometric": "^4.2.2",
    "firebase": "^12.7.0",
    "ionicons": "^8.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.4",
    "@angular/cli": "~21.0.4",
    "@angular/compiler-cli": "^21.0.6",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.0.1",
    "@ionic/angular-toolkit": "^12.1.0",
    "@nxt1/config": "*",
    "@types/jasmine": "^5.1.13",
    "@types/node": "^22.0.0",
    "autoprefixer": "^10.4.23",
    "jasmine-core": "^5.13.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3"
  }
}
