{
  "name": "@nxt1/web",
  "version": "1.0.0",
  "description": "NXT1 Web Application - Angular + Ionic with SSR",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "cross-env NODE_OPTIONS='--max-old-space-size=8192' ng serve",
    "dev:ssr": "cross-env NODE_OPTIONS='--max-old-space-size=8192' ng serve --configuration development",
    "build": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "build:staging": "ng build --configuration staging",
    "serve:ssr": "node dist/nxt1-web/server/server.mjs",
    "serve:ssr:dev": "NODE_ENV=development node dist/nxt1-web/server/server.mjs",
    "build:serve": "npm run build && npm run serve:ssr",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .angular",
    "deploy:staging": "npm run build:staging && firebase deploy --only hosting -P staging",
    "deploy:prod": "npm run build && firebase deploy --only hosting -P production",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "e2e:report": "playwright show-report e2e/playwright-report",
    "e2e:chromium": "playwright test --config=e2e/playwright.config.ts --project=chromium",
    "e2e:firefox": "playwright test --config=e2e/playwright.config.ts --project=firefox",
    "e2e:webkit": "playwright test --config=e2e/playwright.config.ts --project=webkit",
    "e2e:mobile": "playwright test --config=e2e/playwright.config.ts --project=mobile-chrome --project=mobile-safari",
    "e2e:install": "playwright install --with-deps"
  },
  "dependencies": {
    "@ionic/angular": "^8.6.0",
    "@ionic/angular-server": "^8.7.16",
    "@nxt1/core": "*",
    "@nxt1/ui": "*",
    "firebase": "^12.9.0",
    "ionicons": "^8.0.0",
    "rxjs": "~7.8.0",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.0",
    "cross-env": "^7.0.3"
  },
  "devDependencies": {
    "@ionic/angular-toolkit": "^12.1.0",
    "@nxt1/config": "*",
    "@playwright/test": "^1.49.0",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^25.2.3",
    "autoprefixer": "^10.4.23",
    "jasmine-core": "^6.0.1",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "msw": "^2.13.1",
    "postcss": "^8.5.9",
    "typescript": "~5.9.3"
  }
}
