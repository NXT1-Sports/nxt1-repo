{
  "name": "@nxt1/web",
  "version": "1.0.0",
  "description": "NXT1 Web Application - Angular + Ionic with SSR",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve",
    "dev:ssr": "ng serve --configuration development",
    "build": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "build:staging": "ng build --configuration staging",
    "prebuild": "cd ../.. && npm run build --workspace=@nxt1/core",
    "serve:ssr": "node dist/nxt1-web/server/server.mjs",
    "serve:ssr:dev": "NODE_ENV=development node dist/nxt1-web/server/server.mjs",
    "build:serve": "npm run build && npm run serve:ssr",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .angular",
    "deploy:staging": "npm run build:staging && firebase deploy --only hosting -P staging",
    "deploy:prod": "npm run build && firebase deploy --only hosting -P production"
  },
  "dependencies": {
    "@angular-devkit/build-angular": "^21.0.4",
    "@angular/animations": "^21.0.6",
    "@angular/cdk": "^21.0.5",
    "@angular/cli": "~21.0.4",
    "@angular/common": "^21.0.6",
    "@angular/compiler": "^21.0.6",
    "@angular/compiler-cli": "^21.0.6",
    "@angular/core": "^21.0.6",
    "@angular/fire": "^21.0.0-rc.0",
    "@angular/forms": "^21.0.6",
    "@angular/platform-browser": "^21.0.6",
    "@angular/platform-browser-dynamic": "^21.0.6",
    "@angular/platform-server": "^21.0.6",
    "@angular/router": "^21.0.6",
    "@angular/service-worker": "^21.0.6",
    "@angular/ssr": "^21.0.4",
    "@ionic/angular": "^8.6.0",
    "@nxt1/core": "*",
    "@nxt1/ui": "*",
    "firebase": "^12.7.0",
    "ionicons": "^8.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@ionic/angular-toolkit": "^12.1.0",
    "@nxt1/config": "*",
    "@types/jasmine": "^5.1.13",
    "@types/node": "^22.19.5",
    "jasmine-core": "^5.13.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "typescript": "~5.9.3"
  }
}
