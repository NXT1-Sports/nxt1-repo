{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/main*.js",
          "/polyfills*.js",
          "/runtime*.js"
        ]
      }
    },
    {
      "name": "common-chunks",
      "installMode": "prefetch",
      "updateMode": "lazy",
      "resources": {
        "files": ["/chunk-*.js", "/common*.js"]
      }
    },
    {
      "name": "fonts",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/**/*.woff2", "/**/*.woff", "/**/*.ttf"],
        "urls": [
          "https://fonts.googleapis.com/**",
          "https://fonts.gstatic.com/**"
        ]
      }
    },
    {
      "name": "images",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**/*.png",
          "/assets/**/*.jpg",
          "/assets/**/*.jpeg",
          "/assets/**/*.webp",
          "/assets/**/*.avif",
          "/assets/**/*.svg",
          "/assets/**/*.gif",
          "/assets/**/*.ico"
        ]
      }
    },
    {
      "name": "logo-assets",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/shared/logo/**"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-freshness",
      "urls": [
        "/api/v1/feed/**",
        "/api/v1/activity/**",
        "/api/v1/notifications/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "1m",
        "timeout": "5s"
      }
    },
    {
      "name": "api-performance-profiles",
      "urls": ["/api/v1/profile/**", "/api/v1/team/**", "/api/v1/user/**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 100,
        "maxAge": "15m"
      }
    },
    {
      "name": "api-performance-static",
      "urls": [
        "/api/v1/college/**",
        "/api/v1/explore/**",
        "/api/v1/sitemap/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 200,
        "maxAge": "1h"
      }
    }
  ],
  "navigationUrls": ["/**", "!/**/*.*", "!/**/api/**"],
  "navigationRequestStrategy": "freshness"
}
