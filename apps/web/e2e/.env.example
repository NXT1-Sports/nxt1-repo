# =============================================================================
# E2E Test Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment
# NEVER commit actual credentials to the repository
# =============================================================================

# Base URL for tests (default: http://localhost:4200)
E2E_BASE_URL=http://localhost:4200

# Test user credentials (use dedicated test accounts)
E2E_TEST_USER_EMAIL=e2e-test@example.com
E2E_TEST_USER_PASSWORD=TestPassword123!

# Secondary test user for multi-user scenarios
E2E_TEST_USER_2_EMAIL=e2e-test-2@example.com
E2E_TEST_USER_2_PASSWORD=TestPassword123!

# Firebase test project (optional - for API setup/teardown)
E2E_FIREBASE_PROJECT_ID=nxt1-staging

# API base URL for direct API calls in tests
E2E_API_BASE_URL=https://api-staging.nxt1.com

# Enable visual regression testing (screenshots)
E2E_VISUAL_REGRESSION=false

# Slow motion for debugging (milliseconds)
E2E_SLOW_MO=0
