{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "incremental": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "useDefineForClassFields": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "paths": {
      "@nxt1/core": [
        "packages/core/src/index.ts",
        "packages/core/dist/index.d.ts"
      ],
      "@nxt1/core/*": [
        "packages/core/src/*/index.ts",
        "packages/core/dist/*/index.d.ts"
      ],
      "@nxt1/ui": ["packages/ui/src/index.ts", "packages/ui/dist"],
      "@nxt1/ui/auth": [
        "packages/ui/src/auth/index.ts",
        "packages/ui/dist/auth"
      ],
      "@nxt1/ui/services": [
        "packages/ui/src/services/index.ts",
        "packages/ui/dist/services"
      ],
      "@nxt1/ui/shared": [
        "packages/ui/src/shared/index.ts",
        "packages/ui/dist/shared"
      ],
      "@nxt1/ui/directives": [
        "packages/ui/src/directives/index.ts",
        "packages/ui/dist/directives"
      ],
      "@nxt1/ui/components": [
        "packages/ui/src/components/index.ts",
        "packages/ui/dist/components"
      ],
      "@nxt1/ui/infrastructure": [
        "packages/ui/src/infrastructure/index.ts",
        "packages/ui/dist/infrastructure"
      ],
      "@nxt1/ui/auth-services": [
        "packages/ui/src/auth-services/index.ts",
        "packages/ui/dist/auth-services"
      ],
      "@nxt1/ui/onboarding": [
        "packages/ui/src/onboarding/index.ts",
        "packages/ui/dist/onboarding"
      ],
      "@nxt1/ui/*": ["packages/ui/src/*/index.ts", "packages/ui/dist/*"],
      "@nxt1/config/*": ["packages/config/*"]
    }
  },
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/.turbo/**"
  ]
}
